# FortiAnalyzer MCP Server Configuration
# Copy this file to .env and configure your settings

# =============================================================================
# FortiAnalyzer Connection Settings (Required)
# =============================================================================

# FortiAnalyzer hostname or IP address
FORTIANALYZER_HOST=192.168.1.100

# Authentication: API Token (Recommended for FortiAnalyzer 7.2.2+)
# Generate token in FortiAnalyzer: System Settings > Admin > Administrators
FORTIANALYZER_API_TOKEN=

# Authentication: Username/Password (Alternative)
# Used if API token is not provided
FORTIANALYZER_USERNAME=admin
FORTIANALYZER_PASSWORD=

# SSL Certificate Verification
# SECURITY: Keep this 'true'. Disabling verification exposes the FortiAnalyzer
# API token and all log/PCAP data to man-in-the-middle interception. For a
# self-signed FAZ certificate, import the FAZ CA into your system/container
# trust store instead of setting this to false.
FORTIANALYZER_VERIFY_SSL=true

# Request timeout in seconds
FORTIANALYZER_TIMEOUT=30

# Maximum retry attempts for failed requests
FORTIANALYZER_MAX_RETRIES=3

# =============================================================================
# MCP Server Settings
# =============================================================================

# Server bind address.
# SECURITY: 0.0.0.0 exposes the server on every interface. Prefer 127.0.0.1
# (local only) or an internal interface unless you have a reason to publish it
# more broadly, and always pair a 0.0.0.0 bind with MCP_AUTH_TOKEN.
MCP_SERVER_HOST=127.0.0.1

# Server port
MCP_SERVER_PORT=8001

# Host address docker-compose publishes the port on (compose deployments only).
# Defaults to loopback; set to an internal interface IP to allow off-host
# clients, or 0.0.0.0 (not recommended) for all interfaces.
MCP_BIND_ADDRESS=127.0.0.1

# Server mode: 'http' for Docker, 'stdio' for Claude Desktop, 'auto' to detect
MCP_SERVER_MODE=auto

# Bearer token for HTTP authentication.
# SECURITY: In HTTP mode, if this is unset, EVERY tool is exposed
# UNAUTHENTICATED to anyone who can reach the port (log search, device
# add/delete, PCAP download). Set a strong token whenever the server is
# reachable beyond localhost. Generate one with: openssl rand -hex 32
# If set, all HTTP requests (except /health) require Authorization: Bearer <token>
# MCP_AUTH_TOKEN=

# Additional allowed Host header values for DNS rebinding protection.
# The MCP SDK rejects non-localhost Host headers by default. Set this to
# the value the client puts in its connection URL — NOT the client's IP.
# Format: JSON array. Examples:
#   - Reverse-proxy hostname:    ["mcp.example.com"]
#   - Direct Docker IP+port:     ["10.1.5.62:8001"]
#   - Port wildcard (any port):  ["10.1.5.62:*"]
# MCP_ALLOWED_HOSTS=

# Tool loading mode:
# - 'full': Load all tools (higher context usage, ~50K+ tokens)
# - 'dynamic': Load discovery tools only (lower context usage, ~3K tokens)
FAZ_TOOL_MODE=full

# Skills layer (beta, RFC #44): registers the faz_skill dispatcher tool —
# opinionated multi-tool orchestrations (incidents, reports, log_search,
# triage, investigation_report). Read-only. Off by default; requires
# FAZ_TOOL_MODE=full.
# FAZ_SKILLS_ENABLED=false

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Optional log file path (leave empty for console only)
LOG_FILE=logs/fortianalyzer-mcp.log

# Log format
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# =============================================================================
# Security Settings (Optional)
# =============================================================================
# Comma-separated list of allowed output directories for reports and PCAPs.
# SECURE BY DEFAULT: File output is disabled unless explicitly configured.
# Only tools that write files (save_report, download_pcap) require this setting.
# All query/read tools work without it.
# FAZ_ALLOWED_OUTPUT_DIRS=~/Downloads

# =============================================================================
# Default ADOM (Optional)
# =============================================================================

# Default ADOM for all operations (if not specified in tool calls)
DEFAULT_ADOM=root

# =============================================================================
# Testing Configuration (Optional)
# =============================================================================

# Default ADOM for tests (overrides DEFAULT_ADOM for test runs)
TEST_ADOM=root

# Device name for device-specific tests
TEST_DEVICE=

# Skip write operations during tests
TEST_SKIP_WRITE_TESTS=false
